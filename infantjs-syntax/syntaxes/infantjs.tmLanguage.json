{
  "name": "InfantJS",
  "scopeName": "source.infantjs",
  "fileTypes": ["infant"],
  "patterns": [
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#booleans" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "keywords": {
      "match": "\\b(mine|gibberish|peekaboo|nuhuh|wawawa|playtime|bedtime|nomnom|flippy|nap|crawl|climb|roll)\\b",
      "name": "keyword.control.infantjs"
    },
    "types": {
      "match": "\\b(numba|babble|squarehole)\\b",
      "name": "storage.type.infantjs"
    },
    "booleans": {
      "match": "\\b(gaagaa|googoo)\\b",
      "name": "constant.language.infantjs"
    },
    "strings": {
      "begin": "\"",
      "end": "\"",
      "name": "string.quoted.double.infantjs",
      "patterns": [{
        "match": "\\\\.",
        "name": "constant.character.escape.infantjs"
      }]
    },
    "numbers": {
      "match": "\\b[0-9]+(\\.[0-9]+)?\\b",
      "name": "constant.numeric.infantjs"
    },
    "operators": {
      "match": "(==|!=|<=|>=|<|>|\\+|-|\\*\\*|\\*|/|%|=)",
      "name": "keyword.operator.infantjs"
    },
    "functions": {
      "match": "\\b([a-zA-Z][a-zA-Z0-9]*)(?=\\s*\\()",
      "name": "entity.name.function.infantjs"
    }
  }
}